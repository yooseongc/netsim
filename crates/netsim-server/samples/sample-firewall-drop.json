{
  "version": "1.0",
  "name": "sample-firewall-drop",
  "description": "Firewall DROP - Packet to port 80 is blocked by nftables filter. The input chain has a drop policy and only accepts TCP port 22 (SSH).",
  "interfaces": [
    {
      "name": "eth0",
      "index": 2,
      "mac": "02:00:0a:00:00:01",
      "addresses": [
        { "ip": "10.0.0.1", "prefix_len": 24, "scope": "global" }
      ],
      "mtu": 1500,
      "state": "up",
      "kind": "physical"
    }
  ],
  "routing_tables": [
    {
      "id": 255,
      "name": "local",
      "routes": [
        { "destination": "10.0.0.1/32", "dev": "eth0", "scope": "host", "route_type": "local" }
      ]
    },
    {
      "id": 254,
      "name": "main",
      "routes": [
        { "destination": "10.0.0.0/24", "dev": "eth0", "scope": "link" }
      ]
    }
  ],
  "ip_rules": [
    { "priority": 0, "action": { "lookup": 255 } },
    { "priority": 32766, "action": { "lookup": 254 } }
  ],
  "netfilter": {
    "nftables": {
      "tables": [
        {
          "family": "ip",
          "name": "filter",
          "chains": [
            {
              "name": "input",
              "chain_type": "filter",
              "hook": "input",
              "priority": 0,
              "policy": "drop",
              "rules": [
                {
                  "matches": [
                    { "type": "transport", "protocol": "tcp", "field": "dport", "op": "eq", "value": "22" }
                  ],
                  "action": { "type": "verdict", "verdict": "accept" },
                  "comment": "Allow SSH"
                }
              ]
            }
          ]
        }
      ]
    }
  },
  "packet": {
    "ingress_interface": "eth0",
    "src_mac": "02:00:0a:00:00:64",
    "dst_mac": "02:00:0a:00:00:01",
    "src_ip": "10.0.0.100",
    "dst_ip": "10.0.0.1",
    "protocol": "tcp",
    "src_port": 55000,
    "dst_port": 80,
    "tcp_flags": { "syn": true },
    "ttl": 64
  },
  "topology": {
    "endpoints": [
      { "role": "remote_client", "name": "Attacker", "ip": "10.0.0.100", "port": 55000, "interface": "eth0" },
      { "role": "local_server", "name": "Web Server", "ip": "10.0.0.1", "port": 80 }
    ],
    "flows": [
      { "name": "Blocked HTTP", "source": "Attacker", "destination": "Web Server", "protocol": "tcp", "description": "HTTP request dropped by firewall (only SSH allowed)" }
    ]
  }
}
