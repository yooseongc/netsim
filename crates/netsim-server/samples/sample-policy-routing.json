{
  "version": "1.0",
  "name": "sample-policy-routing",
  "description": "Policy routing with fwmark - TCP port 443 traffic is marked with fwmark 1 by nftables mangle, then routed via alternate table 100 through eth1 instead of the default route.",
  "interfaces": [
    {
      "name": "eth0",
      "index": 2,
      "mac": "02:00:0a:00:00:01",
      "addresses": [
        { "ip": "10.0.0.1", "prefix_len": 24, "scope": "global" }
      ],
      "mtu": 1500,
      "state": "up",
      "kind": "physical"
    },
    {
      "name": "eth1",
      "index": 3,
      "mac": "02:00:ac:10:00:01",
      "addresses": [
        { "ip": "172.16.0.1", "prefix_len": 24, "scope": "global" }
      ],
      "mtu": 1500,
      "state": "up",
      "kind": "physical"
    },
    {
      "name": "eth2",
      "index": 4,
      "mac": "02:00:c0:a8:01:01",
      "addresses": [
        { "ip": "192.168.1.1", "prefix_len": 24, "scope": "global" }
      ],
      "mtu": 1500,
      "state": "up",
      "kind": "physical"
    }
  ],
  "routing_tables": [
    {
      "id": 255,
      "name": "local",
      "routes": [
        { "destination": "10.0.0.1/32", "dev": "eth0", "scope": "host", "route_type": "local" },
        { "destination": "172.16.0.1/32", "dev": "eth1", "scope": "host", "route_type": "local" },
        { "destination": "192.168.1.1/32", "dev": "eth2", "scope": "host", "route_type": "local" }
      ]
    },
    {
      "id": 254,
      "name": "main",
      "routes": [
        { "destination": "10.0.0.0/24", "dev": "eth0", "scope": "link" },
        { "destination": "172.16.0.0/24", "dev": "eth1", "scope": "link" },
        { "destination": "192.168.1.0/24", "dev": "eth2", "scope": "link" },
        { "destination": "0.0.0.0/0", "gateway": "192.168.1.254", "dev": "eth2" }
      ]
    },
    {
      "id": 100,
      "name": "alternate",
      "routes": [
        { "destination": "0.0.0.0/0", "gateway": "172.16.0.254", "dev": "eth1" }
      ]
    }
  ],
  "ip_rules": [
    { "priority": 0, "action": { "lookup": 255 } },
    {
      "priority": 100,
      "selector": { "fwmark": 1 },
      "action": { "lookup": 100 }
    },
    { "priority": 32766, "action": { "lookup": 254 } }
  ],
  "netfilter": {
    "nftables": {
      "tables": [
        {
          "family": "ip",
          "name": "mangle",
          "chains": [
            {
              "name": "prerouting",
              "chain_type": "mangle",
              "hook": "prerouting",
              "priority": -150,
              "policy": "accept",
              "rules": [
                {
                  "matches": [
                    { "type": "transport", "protocol": "tcp", "field": "dport", "op": "eq", "value": "443" }
                  ],
                  "action": { "type": "set_mark", "value": 1 },
                  "comment": "Mark HTTPS traffic for policy routing"
                }
              ]
            }
          ]
        }
      ]
    }
  },
  "neighbors": [
    {
      "ip": "172.16.0.254",
      "mac": "02:00:ac:10:00:fe",
      "interface": "eth1",
      "state": "permanent"
    }
  ],
  "sysctl": {
    "ipv4": { "ip_forward": true }
  },
  "packet": {
    "ingress_interface": "eth0",
    "src_mac": "02:00:0a:00:00:64",
    "dst_mac": "02:00:0a:00:00:01",
    "src_ip": "10.0.0.100",
    "dst_ip": "8.8.8.8",
    "protocol": "tcp",
    "src_port": 44000,
    "dst_port": 443,
    "tcp_flags": { "syn": true },
    "ttl": 64
  },
  "topology": {
    "endpoints": [
      { "role": "remote_client", "name": "Client", "ip": "10.0.0.100", "port": 44000, "interface": "eth0" },
      { "role": "remote_server", "name": "HTTPS Server", "ip": "8.8.8.8", "port": 443 }
    ],
    "flows": [
      { "name": "Policy Routed HTTPS", "source": "Client", "destination": "HTTPS Server", "protocol": "tcp", "description": "HTTPS traffic marked with fwmark 1 and routed via alternate table through eth1" }
    ]
  }
}
